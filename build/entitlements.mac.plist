<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron apps running with hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allows loading unsigned dylibs (needed by Electron's V8 engine) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allows Electron to disable library validation (needed for bundled libraries) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- File read/write access for opening and saving scenario folders -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
  </dict>
</plist>
